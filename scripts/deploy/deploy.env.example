# Copy to deploy.env and edit before running install.sh
# cp deploy.env.example deploy.env && nano deploy.env

# Domain & repo
DOMAIN=bookingsalon.tino.page
GIT_REPO=https://github.com/ILoveKroos/BackupBooking.git
GIT_BRANCH=main
INSTALL_DIR=/opt/bookingsalon
WEB_ROOT=/var/www/bookingsalon

# Secrets — CHANGE before production (or leave empty to auto-generate on first install)
MYSQL_ROOT_PASSWORD=
MYSQL_APP_USER=bookingsalon
MYSQL_APP_PASSWORD=
JWT_SECRET=

# Optional: email certbot (recommended for Let's Encrypt expiry notices)
CERTBOT_EMAIL=
